# ---- Build output (Qt Creator "shadow build" folders, CMake build dirs) ----
build/
build-*/
out/
*.o
*.obj
*.exe
*.dll
*.a
*.so
*.dylib

# ---- CMake ----
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake
!CMakeLists.txt

# ---- Qt / Qt Creator generated files ----
*.autosave
*_autogen/
moc_*.cpp
qrc_*.cpp
ui_*.h

# Qt Creator user-specific settings - everyone's local paths differ,
# never share this file
*.user
*.user.*
.qtcreator/

# ---- Database (usually you don't want to commit runtime data) ----
restaurant.db

# ---- OS clutter ----
.DS_Store
Thumbs.db
