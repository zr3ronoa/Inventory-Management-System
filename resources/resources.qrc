<RCC>
    <qresource prefix="/">
        <file>style.qss</file>
    </qresource>
    <qresource prefix="/icons">
        <file alias="box.png">icons/box.png</file>
        <file alias="menu.png">icons/menu.png</file>
        <file alias="receipt.png">icons/receipt.png</file>
        <file alias="clock.png">icons/clock.png</file>
        <file alias="warning.png">icons/warning.png</file>
    </qresource>
</RCC>
